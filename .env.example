# Copy this file to `.env` for local dev. Never commit `.env`.
# In production (Render), set these in the dashboard's Environment tab.

# ---------- Supabase ----------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---------- LLM ----------
ANTHROPIC_API_KEY=sk-ant-xxx
# Or, if using OpenAI instead:
# OPENAI_API_KEY=sk-xxx

# ---------- Admin (for /admin/seed-demo) ----------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_TOKEN=replace-me-with-a-strong-random-string
